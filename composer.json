{
    "name": "blog/abelo-test",
    "description": "Simple blog with categories and posts (PHP + Smarty + MySQL).",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "smarty/smarty": "^5.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
